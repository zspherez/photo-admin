# ── Database (Postgres) ───────────────────────────────────────────
# Pooled connection used at runtime. Direct connection used by Prisma
# migrate (skip the pooler so DDL works). See https://www.prisma.io/docs/orm/overview/databases/postgresql
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# ── App ───────────────────────────────────────────────────────────
APP_BASE_URL="http://127.0.0.1:3000"

# Protected mode requires both values. Production fails closed if either is blank.
ADMIN_PASSWORD=""

# Signs expiring admin session cookies. Generate independently from the password
# (for example: openssl rand -base64 32). Rotating either value revokes sessions.
ADMIN_SESSION_SECRET=""

# Explicit local-only escape hatch for running without authentication.
# Set true only for local development; it is ignored when NODE_ENV=production.
ALLOW_INSECURE_OPEN_MODE="false"

# Bearer token Vercel Cron and GitHub Actions must present on /api/cron/*.
# Requests fail closed if blank.
CRON_SECRET=""

# ── Contact research agent ────────────────────────────────────────
# Optional dedicated token for local workers. Hosted automation uses CRON_SECRET
# so production has one synchronized bearer source of truth.
CONTACT_RESEARCH_AGENT_TOKEN=""
# Optional local worker batch size (1-10, default 3).
CONTACT_RESEARCH_LIMIT="3"

# ── Spotify OAuth ─────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Redirect URI must match exactly. Spotify rejects http://localhost; use 127.0.0.1.
# Registered redirect URI: ${APP_BASE_URL}/api/spotify/callback
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# ── Stats.fm Plus ─────────────────────────────────────────────────
# No public API. Grab the session token from stats.fm after logging in
# (DevTools → Application → Local Storage → "token", or an Authorization header).
STATSFM_TOKEN=""

# ── EDMTrain ──────────────────────────────────────────────────────
# Request a key at https://edmtrain.com/api
EDMTRAIN_API_KEY=""

# ── Resend (transactional email) ──────────────────────────────────
# Key from https://resend.com/api-keys. Sending domain must be verified.
RESEND_API_KEY=""
# Use either you@yourdomain.com or Name <you@yourdomain.com>.
RESEND_FROM_EMAIL="you@yourdomain.com"
# Webhook signing secret (whsec_...) from Resend → Webhooks. Required when the
# webhook is enabled; /api/resend/webhook fails closed if it is blank.
RESEND_WEBHOOK_SECRET=""

# ── Send-time behavior ────────────────────────────────────────────
# Legacy env-based test override. The Settings → General UI also exposes
# this and wins over the env when set (including explicit empty).
SEND_TEST_OVERRIDE=""

# ── Google Sheets (optional contact import) ───────────────────────
# Service account credentials. Provide ONE of:
#   GOOGLE_CREDENTIALS_JSON — raw JSON contents (preferred on Vercel)
#   GOOGLE_CREDENTIALS_PATH — path to the JSON key file on disk
# Protected releases require GOOGLE_CREDENTIALS_JSON independently as a GitHub
# production environment secret; Vercel sensitive values cannot be pulled back.
# GOOGLE_CREDENTIALS_PATH is for local use, not the protected release runner.
# Sync mutates the target sheet by creating/filling the photo_admin_id column.
# Share the sheet with the service account's email as an Editor.
# A successful sync stores sheets_spreadsheet_id and sheets_tab in the database;
# the protected release can also bootstrap them explicitly on its first cutover.
GOOGLE_CREDENTIALS_JSON=""
GOOGLE_CREDENTIALS_PATH=""
SPREADSHEET_ID=""

# Release/adoption-script overrides. Configure both as protected GitHub
# production environment variables or secrets for the first cutover when the
# database does not already contain the exact Sheet target. They are not
# runtime app overrides. Direct script use can set
# SHEETS_TARGET_CHANGE_CONFIRMATION exactly to CONFIRM for an intentional
# replacement. The protected workflow instead requires its explicit
# sheet_target_change_confirmation dispatch input for that one release.
SHEETS_SPREADSHEET_ID=""
SHEETS_TAB=""
SHEETS_TARGET_CHANGE_CONFIRMATION=""
