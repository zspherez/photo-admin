generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model IntegrationCredential {
  id           String    @id @default(cuid())
  provider     String    @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  meta         String?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())
}

model IntegrationSyncLease {
  key        String   @id
  ownerToken String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
}

model ArtistIdentityNameClaim {
  normalizedName String   @id
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Artist {
  id                 String                @id @default(cuid())
  name               String
  normalizedName     String
  spotifyId          String?               @unique
  statsfmId          String?               @unique
  edmtrainId         Int?                  @unique
  genres             String?
  popularity         Int?
  imageUrl           String?
  contacts           Contact[]
  shows              ShowArtist[]
  listenSignals      ListenSignal[]
  playlists          ArtistPlaylist[]
  outreaches         Outreach[]
  contactResearchJob ContactResearchJob?
  researchSkips      ArtistResearchSkip[]
  contactAuditJobs   ContactAuditJob[]
  contactAuditDecisions ContactAuditArtistDecision[]
  trajectoryRuns     TrajectoryRunArtist[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([normalizedName])
}

enum TrajectoryRunStatus {
  importing
  ready
  stale
  superseded
  failed
}

enum TrajectoryArm {
  trajectory
  momentum
  exploration
  portfolio
}

enum TrajectoryCoverageState {
  C_covered
  U0_unresolved
  U1_no_history
  U2_thin_history
  Q_query_incomplete
  Q_query_failure
  J_junk
}

enum TrajectoryImportIssueCode {
  show_not_found
  artist_not_found
  show_artist_membership_missing
}

enum TrajectoryFeedbackAction {
  selected
  declined
  saved
  dismissed
  manual_override
}

enum TrajectoryAccessOutcome {
  none
  guestlist
  photo_pass
  other
}

enum TrajectoryShootability {
  good
  ok
  poor
}

enum TrajectoryVenueAccessibility {
  high
  medium
  low
}

model TrajectoryModelRun {
  id                    String                     @id @default(cuid())
  producer              String
  producerRunId         String
  contractVersion       String
  producerSchemaVersion String
  artifactSha256        String
  fullArtifactSha256    String
  artifactGzip          Bytes?
  artifactByteLength    Int
  producerRevision      String?
  generatedAt           DateTime
  asOfDate              DateTime                   @db.Date
  decisionDate          DateTime                   @db.Date
  minimumShowDate       DateTime                   @db.Date
  validUntil            DateTime
  modelStatus           String
  validationReference   String?
  status                TrajectoryRunStatus
  summary               Json?
  failureCode           String?
  failureMessage        String?
  importedAt            DateTime                   @default(now())
  activatedAt           DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  artists               TrajectoryRunArtist[]
  recommendations       TrajectoryRecommendation[]
  importIssues          TrajectoryImportIssue[]

  @@unique([producer, producerRunId])
  @@unique([producer, artifactSha256])
  @@index([status, generatedAt])
  @@index([validUntil])
}

model TrajectoryRunArtist {
  id               String                     @id @default(cuid())
  runId            String
  run              TrajectoryModelRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  artistId         String?
  artist           Artist?                    @relation(fields: [artistId], references: [id], onDelete: SetNull)
  edmtrainArtistId Int
  sourceName       String
  spotifyArtistId  String?
  raArtistId       String?
  coverageState    TrajectoryCoverageState
  momentumBand     String?
  isEarlyStage     Boolean
  isEstablished    Boolean
  isVeteran        Boolean
  eventDelta6m     Int?
  eventsPrior6m    Int?
  eventsRecent6m   Int?
  marketsPrior6m   Int?
  marketsRecent6m  Int?
  careerAgeYears   Float?
  analogSummary    Json?
  releaseContext   Json?
  genres           Json?
  createdAt        DateTime                   @default(now())
  recommendations  TrajectoryRecommendation[]

  @@unique([runId, edmtrainArtistId])
  @@index([runId, coverageState])
  @@index([artistId])
}

model TrajectoryRecommendation {
  id                String              @id @default(cuid())
  runId             String
  run               TrajectoryModelRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  showId            String
  show              Show                @relation(fields: [showId], references: [id], onDelete: Cascade)
  runArtistId       String
  runArtist         TrajectoryRunArtist @relation(fields: [runArtistId], references: [id], onDelete: Cascade)
  arm               TrajectoryArm
  listRank          Int
  isSuggested       Boolean             @default(false)
  slatePosition     Int?
  billingPosition   Int
  lineupSize        Int
  isFirstBilled     Boolean
  rationale         Json?
  sourceFingerprint String
  createdAt         DateTime            @default(now())
  feedback          TrajectoryFeedbackEvent[]
  outcomes          TrajectoryShowOutcome[]
  outreaches        Outreach[]

  @@unique([runId, showId, runArtistId, arm])
  @@unique([runId, arm, listRank])
  @@index([runId, arm, listRank])
  @@index([runId, isSuggested, slatePosition])
  @@index([showId])
}

model TrajectoryImportIssue {
  id                String                    @id @default(cuid())
  runId             String
  run               TrajectoryModelRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  recommendationKey String?
  code              TrajectoryImportIssueCode
  detail            Json?
  createdAt         DateTime                  @default(now())

  @@index([runId, code])
}

model TrajectoryFeedbackEvent {
  id               String                     @id @default(cuid())
  recommendationId String
  recommendation   TrajectoryRecommendation   @relation(fields: [recommendationId], references: [id], onDelete: Restrict)
  action           TrajectoryFeedbackAction
  propensity       Float?
  manualOverride   Boolean                    @default(false)
  notes            String?
  idempotencyKey   String                     @unique
  supersedesId     String?                    @unique
  supersedes       TrajectoryFeedbackEvent?   @relation("TrajectoryFeedbackSupersession", fields: [supersedesId], references: [id], onDelete: Restrict)
  supersededBy     TrajectoryFeedbackEvent?   @relation("TrajectoryFeedbackSupersession")
  recordedAt       DateTime                   @default(now())

  @@index([recommendationId, recordedAt])
  @@index([action, recordedAt])
}

model TrajectoryShowOutcome {
  id                   String                          @id @default(cuid())
  recommendationId     String
  recommendation       TrajectoryRecommendation        @relation(fields: [recommendationId], references: [id], onDelete: Restrict)
  attended             Boolean?
  access               TrajectoryAccessOutcome?
  keeperCount          Int?
  relationshipValue    Int?
  publicationValue     Int?
  shootability         TrajectoryShootability?
  venueAccessibility   TrajectoryVenueAccessibility?
  notes                String?
  idempotencyKey       String                          @unique
  supersedesId         String?                         @unique
  supersedes           TrajectoryShowOutcome?          @relation("TrajectoryOutcomeSupersession", fields: [supersedesId], references: [id], onDelete: Restrict)
  supersededBy         TrajectoryShowOutcome?          @relation("TrajectoryOutcomeSupersession")
  recordedAt           DateTime                        @default(now())

  @@index([recommendationId, recordedAt])
  @@index([recordedAt])
}

model TrajectoryIngestRequest {
  idempotencyKey String   @id
  ownerToken     String
  producerRunId  String
  artifactSha256 String
  mode           String
  producedAt     DateTime
  status         String
  response       Json?
  httpStatus     Int?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([producerRunId, artifactSha256, mode, status])
}

model SpotifyPlaylist {
  id        String           @id @default(cuid())
  spotifyId String           @unique
  name      String
  url       String
  artists   ArtistPlaylist[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ArtistPlaylist {
  artistId   String
  playlistId String
  artist     Artist          @relation(fields: [artistId], references: [id], onDelete: Cascade)
  playlist   SpotifyPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([artistId, playlistId])
  @@index([playlistId])
}

enum ContactState {
  active
  quarantined
}

model Contact {
  id                 String            @id @default(cuid())
  artistId           String
  artist             Artist            @relation(fields: [artistId], references: [id], onDelete: Cascade)
  email              String?
  phone              String?
  directOutreachNote String?
  /// Stable hash for an agent-created artist/manager direct-outreach identity.
  directOutreachIdentity String? @unique
  directOutreachSourceJobId String?
  directOutreachRuleVersion Int?
  directOutreachRuleText String?
  directOutreachManagerName String?
  directOutreachManagerCompany String?
  directOutreachEvidenceUrls String[] @default([])
  directOutreachEvidence String?
  name               String?
  role               String?
  customPrice        String?
  notes              String?
  source             String?
  /// Historical provider-owned identity retained for provenance.
  sourceKey          String?           @unique
  sourceSyncedAt     DateTime?
  /// Only active contacts are eligible for normal selection; quarantined preserves unresolved legacy history.
  state              ContactState      @default(active)
  isFullTeam         Boolean           @default(false)
  outreaches         Outreach[]
  auditJobs          ContactAuditJob[]
  auditDecisionMutations ContactAuditDecisionContact[]
  createdByAuditDecisions ContactAuditArtistDecision[] @relation("ContactAuditCreatedContact")
  researchDirectOutreachProposals ContactResearchDirectOutreachProposal[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([artistId, email])
  @@index([artistId])
  @@index([source])
  @@index([state])
}

model ContactExportSnapshot {
  id              String   @id
  provider        String   @default("google_sheets")
  status          String   @default("pending")
  idempotencyKey  String   @unique
  contactCount    Int
  contentSha256   String
  spreadsheetId   String
  sheetTabId      Int?
  sheetTabName    String
  sheetUrl        String?
  requestedByRole String
  canonicalRows   Json
  error           String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

model ContactAuditRun {
  id              String                       @id @default(cuid())
  status          String                       @default("running")
  contactCount    Int
  completedAt     DateTime?
  request         ContactAuditRequest?
  jobs            ContactAuditJob[]
  rosterSnapshots ContactAuditRosterSnapshot[]
  artistDecisions ContactAuditArtistDecision[]
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  @@index([status, createdAt])
}

model ContactAuditRosterSnapshot {
  id                 String                    @id @default(cuid())
  runId              String
  run                ContactAuditRun           @relation(fields: [runId], references: [id], onDelete: Restrict)
  snapshotArtistId   String
  snapshotArtistName String
  entries            ContactAuditRosterEntry[]
  jobs               ContactAuditJob[]
  createdAt          DateTime                  @default(now())

  @@unique([runId, snapshotArtistId])
  @@index([snapshotArtistId])
}

model ContactAuditRosterEntry {
  id                         String                     @id @default(cuid())
  rosterSnapshotId           String
  rosterSnapshot             ContactAuditRosterSnapshot @relation(fields: [rosterSnapshotId], references: [id], onDelete: Cascade)
  snapshotContactId          String
  snapshotEmail              String?
  snapshotPhone              String?
  snapshotDirectOutreachNote String?
  snapshotName               String?
  snapshotRole               String?
  snapshotSource             String?
  snapshotNotes              String?
  snapshotIsFullTeam         Boolean                    @default(false)
  targetedByJob              ContactAuditJob?           @relation("ContactAuditTargetRosterEntry")
  createdAt                  DateTime                   @default(now())

  @@unique([rosterSnapshotId, snapshotContactId])
  @@index([snapshotContactId])
}

model ContactAuditRequest {
  id                String           @id @default(cuid())
  requestKey        String?          @unique
  source            String           @default("manual")
  status            String           @default("pending")
  requestedAt       DateTime         @default(now())
  startedAt         DateTime?
  completedAt       DateTime?
  runId             String?          @unique
  run               ContactAuditRun? @relation(fields: [runId], references: [id], onDelete: Restrict)
  attemptCount      Int              @default(0)
  lastAttemptAt     DateTime?
  lastWorkflowRunId String?
  lastError         String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status, requestedAt])
  @@index([requestedAt])
}

model ContactAuditJob {
  id                         String                      @id @default(cuid())
  runId                      String
  run                        ContactAuditRun             @relation(fields: [runId], references: [id], onDelete: Cascade)
  contactId                  String?
  contact                    Contact?                    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  artistId                   String?
  artist                     Artist?                     @relation(fields: [artistId], references: [id], onDelete: SetNull)
  rosterSnapshotId           String?
  rosterSnapshot             ContactAuditRosterSnapshot? @relation(fields: [rosterSnapshotId], references: [id], onDelete: Restrict)
  targetRosterEntryId        String?                     @unique
  targetRosterEntry          ContactAuditRosterEntry?    @relation("ContactAuditTargetRosterEntry", fields: [targetRosterEntryId], references: [id], onDelete: Restrict)
  snapshotArtistName         String
  snapshotEmail              String?
  snapshotPhone              String?
  snapshotDirectOutreachNote String?
  snapshotName               String?
  snapshotRole               String?
  snapshotSource             String?
  snapshotNotes              String?
  snapshotIsFullTeam         Boolean?
  status                     String                      @default("pending")
  attemptCount               Int                         @default(0)
  claimedAt                  DateTime?
  claimExpiresAt             DateTime?
  claimToken                 String?                     @unique
  claimedAgentRules          String?
  claimedAgentRulesVersion   Int?
  claimedAutoAppendAdditionalContact Boolean?
  finding                    String?
  sourceUrls                 String[]                    @default([])
  evidence                   String?
  confidence                 String?
  agentNotes                 String?
  rosterReview               Json?
  verifiedAt                 DateTime?
  reviewedAt                 DateTime?
  resolution                 String?
  resolvedAt                 DateTime?
  selectedAlternativeId      String?
  selectedAlternative        ContactAuditAlternative?    @relation("ContactAuditSelectedAlternative", fields: [selectedAlternativeId], references: [id], onDelete: Restrict)
  resolvedContactId          String?
  resolvedArtistId           String?
  resolvedArtistName         String?
  resolvedEmail              String?
  resolvedPhone              String?
  resolvedDirectOutreachNote String?
  resolvedName               String?
  resolvedRole               String?
  resolvedSource             String?
  resolvedState              String?
  resolutionClaimToken       String?                     @unique
  resolutionClaimedAt        DateTime?
  alternatives               ContactAuditAlternative[]
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  @@unique([runId, contactId])
  @@index([runId, status, createdAt])
  @@index([runId, resolution, finding, verifiedAt])
  @@index([status, claimExpiresAt])
  @@index([finding, reviewedAt, verifiedAt])
  @@index([contactId])
  @@index([artistId])
  @@index([rosterSnapshotId])
}

model ContactAuditAlternative {
  id              String            @id @default(cuid())
  jobId           String
  job             ContactAuditJob   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  normalizedEmail String
  email           String
  name            String?
  role            String
  sourceUrls      String[]          @default([])
  evidence        String
  confidence      String
  selectedByJobs  ContactAuditJob[] @relation("ContactAuditSelectedAlternative")
  selectedByArtistDecisions ContactAuditArtistDecision[] @relation("ContactAuditArtistSelectedAlternative")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([jobId, normalizedEmail])
  @@index([jobId, createdAt])
}

model ContactAuditArtistDecision {
  id                    String                       @id @default(cuid())
  runId                 String
  run                   ContactAuditRun              @relation(fields: [runId], references: [id], onDelete: Restrict)
  artistId              String
  artist                Artist                       @relation(fields: [artistId], references: [id], onDelete: Restrict)
  snapshotArtistName    String
  action                String
  selectedAlternativeId String?
  selectedAlternative   ContactAuditAlternative?     @relation("ContactAuditArtistSelectedAlternative", fields: [selectedAlternativeId], references: [id], onDelete: Restrict)
  createdContactId      String?
  createdContact        Contact?                     @relation("ContactAuditCreatedContact", fields: [createdContactId], references: [id], onDelete: Restrict)
  contactMutations      ContactAuditDecisionContact[]
  resolvedAt            DateTime
  createdAt             DateTime                     @default(now())

  @@unique([runId, artistId])
  @@index([artistId, resolvedAt])
  @@index([selectedAlternativeId])
  @@index([createdContactId])
}

model ContactAuditDecisionContact {
  decisionId                 String
  decision                   ContactAuditArtistDecision @relation(fields: [decisionId], references: [id], onDelete: Restrict)
  contactId                  String
  contact                    Contact                    @relation(fields: [contactId], references: [id], onDelete: Restrict)
  action                     String
  snapshotEmail              String?
  snapshotPhone              String?
  snapshotDirectOutreachNote String?
  snapshotName               String?
  snapshotRole               String?
  snapshotSource             String?
  snapshotNotes              String?
  snapshotIsFullTeam         Boolean
  createdAt                  DateTime                   @default(now())

  @@id([decisionId, contactId])
  @@index([contactId])
}

model ContactResearchJob {
  id                       String                     @id @default(cuid())
  artistId                 String                     @unique
  artist                   Artist                     @relation(fields: [artistId], references: [id], onDelete: Cascade)
  requestedShowId          String?
  requestedShow            Show?                      @relation(fields: [requestedShowId], references: [id], onDelete: SetNull)
  status                   String                     @default("pending")
  priority                 Int                        @default(0)
  nextShowAt               DateTime?
  attemptCount             Int                        @default(0)
  claimedAt                DateTime?
  claimExpiresAt           DateTime?
  claimToken               String?                    @unique
  claimedAgentRules        String?
  claimedAgentRulesVersion Int?
  claimedDirectOutreachRules Json?
  userNotes                String?
  agentNotes               String?
  completedAt              DateTime?
  candidates               ContactResearchCandidate[]
  directOutreachProposals  ContactResearchDirectOutreachProposal[]
  researchSkips            ArtistResearchSkip[]
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  @@index([status, priority, nextShowAt, createdAt])
  @@index([claimExpiresAt])
  @@index([requestedShowId])
}

model ArtistResearchSkip {
  id               String              @id @default(cuid())
  artistId         String
  artist           Artist              @relation(fields: [artistId], references: [id], onDelete: Cascade)
  source           String
  reason           String
  sourceJobId      String?
  sourceJob        ContactResearchJob? @relation(fields: [sourceJobId], references: [id], onDelete: NoAction)
  agentRuleVersion Int?
  agentRuleText    String?
  setAt            DateTime            @default(now())
  clearedAt        DateTime?
  clearedBy        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([artistId, clearedAt])
  @@index([sourceJobId])
}

model ContactResearchCandidate {
  id                      String             @id @default(cuid())
  jobId                   String
  job                     ContactResearchJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  normalizedEmail         String
  email                   String
  name                    String?
  role                    String
  sourceUrls              String[]           @default([])
  evidence                String
  confidence              String
  needsApproval           Boolean            @default(true)
  officialSourceType      String?
  officialSourceUrl       String?
  officialManagementLabel String?
  officialSourceEvidence  String?
  status                  String             @default("pending")
  reviewedAt              DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@unique([jobId, normalizedEmail])
  @@index([status, createdAt])
}

model ContactResearchDirectOutreachProposal {
  id                    String             @id @default(cuid())
  jobId                 String
  job                   ContactResearchJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  ruleId                String
  ruleVersion           Int
  canonicalRule         String
  normalizedManagerName String
  managerName           String
  managerCompany        String?
  note                  String
  sourceUrls            String[]           @default([])
  evidenceQuotes        String[]           @default([])
  status                String             @default("pending")
  contactId             String?
  contact               Contact?           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  reviewedAt            DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@unique([jobId, ruleId, normalizedManagerName])
  @@index([status, createdAt])
  @@index([contactId])
}

model Show {
  id                        String                        @id @default(cuid())
  edmtrainId                Int?                          @unique
  edmtrainVenueId           Int?
  edmtrainVenue             EdmtrainVenue?                @relation(fields: [edmtrainVenueId], references: [id], onDelete: SetNull)
  date                      DateTime
  venueName                 String
  city                      String
  state                     String?
  /// ISO 3166-1 alpha-2 when known. Null is explicitly unknown, never assumed US.
  countryCode               String?
  /// Provider/manual display value retained when an ISO code cannot be resolved.
  countryName               String?
  ticketUrl                 String?
  ages                      String?
  electronicGenre           String?
  isFestival                Boolean                       @default(false)
  /// inside_nyc, outside_nyc, or unknown for festival eligibility.
  festivalNycStatus         String?
  eventName                 String?
  source                    String?
  /// Provider status; blocked is retained only for legacy compatibility.
  syncStatus                String                        @default("active")
  sourceLastSeenAt          DateTime?
  sourceGeneration          String?
  dismissedAt               DateTime?
  interestedAt              DateTime?
  raw                       String?
  artists                   ShowArtist[]
  outreaches                Outreach[]
  contactResearchJobs       ContactResearchJob[]
  dashboardSnapshotMembers  DashboardShowSnapshotMember[]
  trajectoryRecommendations TrajectoryRecommendation[]
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt

  @@index([date])
  @@index([edmtrainVenueId])
  @@index([isFestival, date])
  @@index([isFestival, festivalNycStatus, date])
  @@index([isFestival, countryCode, dismissedAt, date])
  @@index([source, syncStatus, date])
  @@index([dismissedAt])
  @@index([interestedAt])
}

model DashboardShowSnapshot {
  id        String                        @id @default(cuid())
  ownerKey  String
  queryKey  String
  total     Int
  expiresAt DateTime
  members   DashboardShowSnapshotMember[]
  createdAt DateTime                      @default(now())

  @@index([expiresAt])
  @@index([ownerKey, queryKey, expiresAt])
}

model DashboardShowSnapshotMember {
  snapshotId String
  position   Int
  showId     String
  sortDate   DateTime
  snapshot   DashboardShowSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  show       Show                  @relation(fields: [showId], references: [id], onDelete: Restrict)

  @@id([snapshotId, position])
  @@unique([snapshotId, showId])
  @@index([showId])
}

model EdmtrainVenue {
  id                    Int      @id
  name                  String
  address               String?
  location              String?
  city                  String?
  state                 String?
  countryCode           String?
  countryName           String?
  latitude              Float?
  longitude             Float?
  /// inside_nyc, outside_nyc, or unknown. Unknown regular shows fail closed.
  nycStatus             String
  nycStatusReason       String
  geographySource       String
  classificationVersion Int
  sourceFingerprint     String?
  lastSeenAt            DateTime
  shows                 Show[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([nycStatus, lastSeenAt])
}

model ShowArtist {
  showId    String
  artistId  String
  show      Show    @relation(fields: [showId], references: [id], onDelete: Cascade)
  artist    Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  headliner Boolean @default(false)

  @@id([showId, artistId])
  @@index([artistId])
}

model ListenSignal {
  id             String    @id @default(cuid())
  artistId       String
  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  source         String
  rank           Int?
  playCount      Int?
  score          Float?
  lastSeenAt     DateTime?
  /// Null for complete ranking/membership snapshots; recent-play signals expire.
  expiresAt      DateTime?
  /// Identifies the complete atomic source snapshot that wrote this signal.
  syncGeneration String?
  fetchedAt      DateTime  @default(now())

  @@unique([artistId, source])
  @@index([artistId])
  @@index([source, expiresAt])
}

model EmailTemplate {
  id         String                @id @default(cuid())
  name       String                @unique
  purpose    EmailTemplatePurpose? @unique
  subject    String
  htmlBody   String
  isDefault  Boolean               @default(false)
  outreaches Outreach[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

enum EmailTemplatePurpose {
  original
  festival
  follow_up
}

enum OutreachKind {
  original
  follow_up
}

model Outreach {
  id                         String                @id @default(cuid())
  kind                       OutreachKind          @default(original)
  parentOutreachId           String?               @unique
  parentOutreach             Outreach?             @relation("OutreachFollowUp", fields: [parentOutreachId], references: [id], onDelete: Cascade)
  followUp                   Outreach?             @relation("OutreachFollowUp")
  showId                     String
  show                       Show                  @relation(fields: [showId], references: [id], onDelete: Cascade)
  artistId                   String
  artist                     Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  contactId                  String?
  contact                    Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  templateId                 String?
  template                   EmailTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  trajectoryRecommendationId String?
  trajectoryRecommendation   TrajectoryRecommendation? @relation(fields: [trajectoryRecommendationId], references: [id], onDelete: Restrict)
  finalSubject               String
  finalHtml                  String
  recipientEmails            String[]              @default([])
  recipientSnapshotState     String                @default("legacy_unknown")
  fullTeamSend               Boolean               @default(false)
  expectedRecipientContactId String?
  expectedRecipientArtistId  String?
  expectedRecipientEmail     String?
  expectedRecipientUpdatedAt DateTime?
  status                     String
  error                      String?
  providerMessageId          String?
  idempotencyKey             String                @unique @default(dbgenerated("('outreach/'::text || md5(((random())::text || (clock_timestamp())::text)))"))
  attemptCount               Int                   @default(0)
  claimedAt                  DateTime?
  claimToken                 String?
  lastAttemptAt              DateTime?
  sentAt                     DateTime?
  deliveredAt                DateTime?
  firstOpenedAt              DateTime?
  lastOpenedAt               DateTime?
  openCount                  Int                   @default(0)
  firstClickedAt             DateTime?
  lastClickedAt              DateTime?
  clickCount                 Int                   @default(0)
  bouncedAt                  DateTime?
  complainedAt               DateTime?
  scheduledFor               DateTime?
  nextAttemptAt              DateTime?
  sendAttempts               OutreachSendAttempt[]
  webhookEvents              ResendWebhookEvent[]
  createdAt                  DateTime              @default(now())

  @@unique([showId, contactId, kind])
  @@index([showId])
  @@index([contactId])
  @@index([artistId])
  @@index([trajectoryRecommendationId])
  @@index([kind, status, scheduledFor])
  @@index([status, scheduledFor])
  @@index([status, nextAttemptAt])
  @@index([status, claimedAt])
}

model OutreachSendAttempt {
  id                      String               @id
  outreachId              String
  outreach                Outreach             @relation(fields: [outreachId], references: [id], onDelete: Cascade)
  status                  String
  idempotencyKey          String               @unique
  providerRequest         Json?
  requestHash             String?
  testSend                Boolean?
  /// Stable SHA-256 fingerprint of the Resend API credential; never the secret key.
  providerCredentialScope String?
  providerMessageId       String?              @unique
  firstAttemptAt          DateTime?
  lastAttemptAt           DateTime?
  attemptCount            Int                  @default(0)
  /// configuration and retryable are proven unsent; in_flight and uncertain may have been accepted.
  failureDisposition      String?
  nextAttemptAt           DateTime?
  acceptedAt              DateTime?
  error                   String?
  deliveredAt             DateTime?
  firstOpenedAt           DateTime?
  lastOpenedAt            DateTime?
  openCount               Int                  @default(0)
  firstClickedAt          DateTime?
  lastClickedAt           DateTime?
  clickCount              Int                  @default(0)
  bouncedAt               DateTime?
  complainedAt            DateTime?
  webhookEvents           ResendWebhookEvent[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([outreachId, createdAt])
  @@index([status, lastAttemptAt])
  @@index([status, nextAttemptAt])
  @@index([providerCredentialScope])
}

model OutreachAttachmentBlob {
  sha256     String   @id
  content    Bytes
  byteLength Int
  createdAt  DateTime @default(now())
}

model EmailSuppression {
  normalizedEmail String   @id
  reason          String
  source          String   @default("resend")
  sourceEventId   String?
  suppressedAt    DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([suppressedAt])
}

model ResendWebhookEvent {
  eventId           String               @id
  type              String
  providerMessageId String?
  recipientEmails   String[]             @default([])
  providerCreatedAt DateTime
  outreachId        String?
  outreach          Outreach?            @relation(fields: [outreachId], references: [id], onDelete: SetNull)
  attemptId         String?
  attempt           OutreachSendAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  arbitraryEmailId  String?
  arbitraryEmail    ArbitraryEmail?      @relation(fields: [arbitraryEmailId], references: [id], onDelete: SetNull)
  correlationStatus String               @default("unmatched")
  correlationError  String?
  processedAt       DateTime             @default(now())

  @@index([outreachId, providerCreatedAt])
  @@index([attemptId, providerCreatedAt])
  @@index([arbitraryEmailId, providerCreatedAt])
}

model ArbitraryEmail {
  id                      String               @id
  recipientEmails         String[]             @default([])
  subject                 String
  html                    String
  text                    String?
  utmSource               String?
  utmMedium               String?
  utmCampaign             String?
  utmContent              String?
  utmTerm                 String?
  status                  String
  error                   String?
  providerMessageId       String?              @unique
  idempotencyKey          String               @unique
  providerRequest         Json?
  requestHash             String?
  testSend                Boolean?
  scheduledFor            DateTime?
  nextAttemptAt           DateTime?
  claimedAt               DateTime?
  claimToken              String?              @unique
  lastAttemptAt           DateTime?
  firstAttemptAt          DateTime?
  attemptCount            Int                  @default(0)
  failureDisposition      String?
  /// Stable SHA-256 fingerprint of the Resend API credential; never the secret key.
  providerCredentialScope String?
  sentAt                  DateTime?
  deliveredAt             DateTime?
  firstOpenedAt           DateTime?
  lastOpenedAt            DateTime?
  openCount               Int                  @default(0)
  firstClickedAt          DateTime?
  lastClickedAt           DateTime?
  clickCount              Int                  @default(0)
  bouncedAt               DateTime?
  complainedAt            DateTime?
  webhookEvents           ResendWebhookEvent[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([status, nextAttemptAt])
  @@index([status, claimedAt])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AgentRuleSet {
  scope        String   @id
  instructions String
  directOutreachRules Json @default("[]")
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
