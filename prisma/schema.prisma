generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model IntegrationCredential {
  id           String    @id @default(cuid())
  provider     String    @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  meta         String?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())
}

model IntegrationSyncLease {
  key        String   @id
  ownerToken String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([expiresAt])
}

model ArtistIdentityNameClaim {
  normalizedName String   @id
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Artist {
  id                 String              @id @default(cuid())
  name               String
  normalizedName     String
  spotifyId          String?             @unique
  statsfmId          String?             @unique
  edmtrainId         Int?                @unique
  genres             String?
  popularity         Int?
  imageUrl           String?
  contacts           Contact[]
  shows              ShowArtist[]
  listenSignals      ListenSignal[]
  playlists          ArtistPlaylist[]
  outreaches         Outreach[]
  contactResearchJob ContactResearchJob?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([normalizedName])
}

model SpotifyPlaylist {
  id        String           @id @default(cuid())
  spotifyId String           @unique
  name      String
  url       String
  artists   ArtistPlaylist[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ArtistPlaylist {
  artistId   String
  playlistId String
  artist     Artist          @relation(fields: [artistId], references: [id], onDelete: Cascade)
  playlist   SpotifyPlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@id([artistId, playlistId])
  @@index([playlistId])
}

enum ContactState {
  active
  quarantined
}

model Contact {
  id                 String       @id @default(cuid())
  artistId           String
  artist             Artist       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  email              String?
  phone              String?
  directOutreachNote String?
  name               String?
  role               String?
  customPrice        String?
  notes              String?
  source             String?
  /// Stable provider-owned identity. Sheet contacts use spreadsheet/tab/row/slot identity.
  sourceKey          String?      @unique
  sourceSyncedAt     DateTime?
  /// Only active contacts are eligible for normal selection; quarantined preserves unresolved legacy history.
  state              ContactState @default(active)
  isFullTeam         Boolean      @default(false)
  outreaches         Outreach[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([artistId, email])
  @@index([artistId])
  @@index([source])
  @@index([state])
}

model ContactResearchJob {
  id                       String                     @id @default(cuid())
  artistId                 String                     @unique
  artist                   Artist                     @relation(fields: [artistId], references: [id], onDelete: Cascade)
  requestedShowId          String?
  requestedShow            Show?                      @relation(fields: [requestedShowId], references: [id], onDelete: SetNull)
  status                   String                     @default("pending")
  priority                 Int                        @default(0)
  nextShowAt               DateTime?
  attemptCount             Int                        @default(0)
  claimedAt                DateTime?
  claimExpiresAt           DateTime?
  claimToken               String?                    @unique
  claimedAgentRules        String?
  claimedAgentRulesVersion Int?
  userNotes                String?
  agentNotes               String?
  completedAt              DateTime?
  candidates               ContactResearchCandidate[]
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt

  @@index([status, priority, nextShowAt, createdAt])
  @@index([claimExpiresAt])
  @@index([requestedShowId])
}

model ContactResearchCandidate {
  id              String             @id @default(cuid())
  jobId           String
  job             ContactResearchJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  normalizedEmail String
  email           String
  name            String?
  role            String
  sourceUrls      String[]           @default([])
  evidence        String
  confidence      String
  needsApproval   Boolean            @default(true)
  officialSourceType                String?
  officialSourceUrl                 String?
  officialManagementLabel           String?
  officialSourceEvidence            String?
  status          String             @default("pending")
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([jobId, normalizedEmail])
  @@index([status, createdAt])
}

model Show {
  id                  String               @id @default(cuid())
  edmtrainId          Int?                 @unique
  edmtrainVenueId     Int?
  edmtrainVenue       EdmtrainVenue?       @relation(fields: [edmtrainVenueId], references: [id], onDelete: SetNull)
  date                DateTime
  venueName           String
  city                String
  state               String?
  /// ISO 3166-1 alpha-2 when known. Null is explicitly unknown, never assumed US.
  countryCode         String?
  /// Provider/manual display value retained when an ISO code cannot be resolved.
  countryName         String?
  ticketUrl           String?
  ages                String?
  electronicGenre     String?
  isFestival          Boolean              @default(false)
  eventName           String?
  source              String?
  /// active, cancelled, blocked, or missing for provider-managed events.
  syncStatus          String               @default("active")
  sourceLastSeenAt    DateTime?
  sourceGeneration    String?
  dismissedAt         DateTime?
  interestedAt        DateTime?
  raw                 String?
  artists             ShowArtist[]
  outreaches          Outreach[]
  contactResearchJobs ContactResearchJob[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([date])
  @@index([edmtrainVenueId])
  @@index([isFestival, date])
  @@index([isFestival, countryCode, dismissedAt, date])
  @@index([source, syncStatus, date])
  @@index([dismissedAt])
  @@index([interestedAt])
}

model EdmtrainVenue {
  id                    Int      @id
  name                  String
  address               String?
  location              String?
  city                  String?
  state                 String?
  countryCode           String?
  countryName           String?
  latitude              Float?
  longitude             Float?
  /// inside_nyc, outside_nyc, or unknown. Unknown regular shows fail closed.
  nycStatus             String
  nycStatusReason       String
  geographySource       String
  classificationVersion Int
  sourceFingerprint     String?
  lastSeenAt            DateTime
  shows                 Show[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([nycStatus, lastSeenAt])
}

model ShowArtist {
  showId    String
  artistId  String
  show      Show    @relation(fields: [showId], references: [id], onDelete: Cascade)
  artist    Artist  @relation(fields: [artistId], references: [id], onDelete: Cascade)
  headliner Boolean @default(false)

  @@id([showId, artistId])
  @@index([artistId])
}

model ListenSignal {
  id             String    @id @default(cuid())
  artistId       String
  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  source         String
  rank           Int?
  playCount      Int?
  score          Float?
  lastSeenAt     DateTime?
  /// Null for complete ranking/membership snapshots; recent-play signals expire.
  expiresAt      DateTime?
  /// Identifies the complete atomic source snapshot that wrote this signal.
  syncGeneration String?
  fetchedAt      DateTime  @default(now())

  @@unique([artistId, source])
  @@index([artistId])
  @@index([source, expiresAt])
}

model EmailTemplate {
  id         String     @id @default(cuid())
  name       String     @unique
  subject    String
  htmlBody   String
  isDefault  Boolean    @default(false)
  outreaches Outreach[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum OutreachKind {
  original
  follow_up
}

model Outreach {
  id                     String                @id @default(cuid())
  kind                   OutreachKind          @default(original)
  parentOutreachId       String?               @unique
  parentOutreach         Outreach?             @relation("OutreachFollowUp", fields: [parentOutreachId], references: [id], onDelete: Cascade)
  followUp               Outreach?             @relation("OutreachFollowUp")
  showId                 String
  show                   Show                  @relation(fields: [showId], references: [id], onDelete: Cascade)
  artistId               String
  artist                 Artist                @relation(fields: [artistId], references: [id], onDelete: Cascade)
  contactId              String?
  contact                Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  templateId             String?
  template               EmailTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  finalSubject           String
  finalHtml              String
  recipientEmails        String[]              @default([])
  recipientSnapshotState String                @default("legacy_unknown")
  fullTeamSend           Boolean               @default(false)
  status                 String
  error                  String?
  providerMessageId      String?
  idempotencyKey         String                @unique @default(dbgenerated("('outreach/'::text || md5(((random())::text || (clock_timestamp())::text)))"))
  attemptCount           Int                   @default(0)
  claimedAt              DateTime?
  claimToken             String?
  lastAttemptAt          DateTime?
  sentAt                 DateTime?
  deliveredAt            DateTime?
  firstOpenedAt          DateTime?
  lastOpenedAt           DateTime?
  openCount              Int                   @default(0)
  firstClickedAt         DateTime?
  lastClickedAt          DateTime?
  clickCount             Int                   @default(0)
  bouncedAt              DateTime?
  complainedAt           DateTime?
  scheduledFor           DateTime?
  nextAttemptAt          DateTime?
  sendAttempts           OutreachSendAttempt[]
  webhookEvents          ResendWebhookEvent[]
  createdAt              DateTime              @default(now())

  @@unique([showId, contactId, kind])
  @@index([showId])
  @@index([contactId])
  @@index([artistId])
  @@index([kind, status, scheduledFor])
  @@index([status, scheduledFor])
  @@index([status, nextAttemptAt])
  @@index([status, claimedAt])
}

model OutreachSendAttempt {
  id                      String               @id
  outreachId              String
  outreach                Outreach             @relation(fields: [outreachId], references: [id], onDelete: Cascade)
  status                  String
  idempotencyKey          String               @unique
  providerRequest         Json?
  requestHash             String?
  testSend                Boolean?
  /// Stable SHA-256 fingerprint of the Resend API credential; never the secret key.
  providerCredentialScope String?
  providerMessageId       String?              @unique
  firstAttemptAt          DateTime?
  lastAttemptAt           DateTime?
  attemptCount            Int                  @default(0)
  /// configuration and retryable are proven unsent; in_flight and uncertain may have been accepted.
  failureDisposition      String?
  nextAttemptAt           DateTime?
  acceptedAt              DateTime?
  error                   String?
  deliveredAt             DateTime?
  firstOpenedAt           DateTime?
  lastOpenedAt            DateTime?
  openCount               Int                  @default(0)
  firstClickedAt          DateTime?
  lastClickedAt           DateTime?
  clickCount              Int                  @default(0)
  bouncedAt               DateTime?
  complainedAt            DateTime?
  webhookEvents           ResendWebhookEvent[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([outreachId, createdAt])
  @@index([status, lastAttemptAt])
  @@index([status, nextAttemptAt])
  @@index([providerCredentialScope])
}

model OutreachAttachmentBlob {
  sha256     String   @id
  content    Bytes
  byteLength Int
  createdAt  DateTime @default(now())
}

model EmailSuppression {
  normalizedEmail String   @id
  reason          String
  source          String   @default("resend")
  sourceEventId   String?
  suppressedAt    DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([suppressedAt])
}

model ResendWebhookEvent {
  eventId           String               @id
  type              String
  providerMessageId String?
  recipientEmails   String[]             @default([])
  providerCreatedAt DateTime
  outreachId        String?
  outreach          Outreach?            @relation(fields: [outreachId], references: [id], onDelete: SetNull)
  attemptId         String?
  attempt           OutreachSendAttempt? @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  correlationStatus String               @default("unmatched")
  correlationError  String?
  processedAt       DateTime             @default(now())

  @@index([outreachId, providerCreatedAt])
  @@index([attemptId, providerCreatedAt])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AgentRuleSet {
  scope        String   @id
  instructions String
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
