{
  "name": "photo-admin",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:generate && next build",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:resolve-failed-migration": "tsx scripts/resolve-failed-migration.ts",
    "db:verify-targets": "tsx scripts/verify-database-targets.ts",
    "db:release-runtime-verification": "tsx scripts/release-runtime-verification.ts",
    "db:verify-release-compatibility": "tsx scripts/verify-release-compatibility.ts",
    "db:backfill:normalized-artists": "tsx scripts/backfill-normalized-artists.ts",
    "db:setup": "npm run db:generate && npm run db:migrate:deploy && npm run db:backfill:normalized-artists",
    "trajectory:import": "tsx scripts/import-trajectory-run.ts",
    "trajectory:promote": "tsx scripts/promote-trajectory-run.ts",
    "trajectory:production:verify": "tsx scripts/verify-trajectory-production.ts",
    "trajectory:feedback:export": "tsx scripts/export-trajectory-feedback.ts",
    "contact-audit:agent": "bash scripts/run-contact-audit-agent.sh",
    "contact-research:agent": "bash scripts/run-contact-research-agent.sh",
    "start": "next start",
    "test": "tsx --test --test-concurrency=1 --import ./scripts/test-environment.mjs \"**/*.{test,spec}.{ts,tsx,mts}\"",
    "test:mobile": "tsx scripts/mobile-pwa-playwright.ts",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint",
    "rotate:statsfm-token": "tsx scripts/rotate-statsfm-token.ts",
    "setup:check": "tsx scripts/setup-check.ts",
    "env:generate": "tsx scripts/generate-env-docs.ts",
    "env:check": "tsx scripts/generate-env-docs.ts --check",
    "postinstall": "npm run db:generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tiptap/extension-link": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "svix": "^1.94.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "1.55.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "zod": "^3.25.76"
  }
}
